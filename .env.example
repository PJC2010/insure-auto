# ── Axon CRM lead intake ──────────────────────────────────────────────────────
# Server-only — read inside pages/api/quote-request.js and pages/api/contact.js,
# never exposed to the browser (no NEXT_PUBLIC_ prefix). Set these in the Vercel
# project's Environment Variables for both Preview and Production, matching the
# PUBLIC_INTAKE_API_KEY / PUBLIC_INTAKE_ACCOUNT_ID generated on the Axon side
# (see axon_crm/.env.example).
AXON_API_URL=
AXON_API_KEY=
